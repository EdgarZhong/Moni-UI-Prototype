--- /dev/null
+++ b/src/index.css
@@ -0,0 +1,51 @@
+/*
+  Moni-UI-Prototype 全局 CSS 防御层（DESIGN.md 23.1）
+  目标：让 F12 移动模式 与 Android WebView 的触控行为尽量一致，避免系统默认手势/菜单干扰。
+*/
+
+/* 1. 禁用双击缩放 — 消除 300ms tap delay */
+html {
+  touch-action: manipulation;
+}
+
+/* 2. 禁用长按系统菜单 — 防止长按时弹出文本选择/链接预览 */
+* {
+  -webkit-touch-callout: none;
+  -webkit-user-select: none;
+  user-select: none;
+}
+
+/* 3. 对需要文本选择的区域单独恢复 */
+input,
+textarea,
+[data-selectable] {
+  -webkit-user-select: text;
+  user-select: text;
+}
+
+/* 4. 防止嵌套滚动穿透（滚动容器需显式打 data-scroll-container 标记） */
+[data-scroll-container] {
+  overscroll-behavior: contain;
+}
+
+/* 5. 禁用 Android WebView 的 overscroll 发光效果 */
+body {
+  overscroll-behavior: none;
+}
+
+/* 6. 禁用默认拖拽行为（避免误触发浏览器拖拽预览） */
+img,
+a,
+svg {
+  -webkit-user-drag: none;
+}
+
+/* --- 额外通用防御（不属于 23.1 六条，但对原型稳定性有帮助） --- */
+* {
+  box-sizing: border-box;
+}
+
+/* 隐藏滚动条（保持 iOS/Android 原生质感） */
+::-webkit-scrollbar {
+  display: none;
+}
